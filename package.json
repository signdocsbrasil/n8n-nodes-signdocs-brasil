{
  "name": "n8n-nodes-signdocs-brasil",
  "version": "0.1.0",
  "description": "n8n community node for SignDocs Brasil — assinatura eletrônica com biometria, OTP, clickwrap e certificados ICP-Brasil A1/A3 em conformidade com a MP 2.200-2",
  "keywords": [
    "n8n-community-node-package",
    "signdocs",
    "assinatura-eletronica",
    "digital-signature",
    "icp-brasil",
    "esignature",
    "brasil"
  ],
  "license": "MIT",
  "homepage": "https://docs.signdocs.com.br",
  "author": {
    "name": "SignDocs Brasil",
    "email": "dev@signdocs.com.br",
    "url": "https://signdocs.com.br"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/signdocsbrasil/n8n-nodes-signdocs-brasil.git"
  },
  "bugs": {
    "url": "https://github.com/signdocsbrasil/n8n-nodes-signdocs-brasil/issues"
  },
  "engines": {
    "node": ">=18.10"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint nodes credentials --ext .ts",
    "lintfix": "eslint nodes credentials --ext .ts --fix",
    "format": "prettier nodes credentials --write",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SignDocsBrasilApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/SignDocsBrasil/SignDocsBrasil.node.js",
      "dist/nodes/SignDocsBrasilTrigger/SignDocsBrasilTrigger.node.js"
    ]
  },
  "dependencies": {
    "@signdocs-brasil/api": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
